# Application
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite+aiosqlite:///./hospital.db

# Ollama (Docker uses http://ollama:11434/api/generate automatically)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
# Ngrok tunnel HTTP basic auth (set OLLAMA_URL to your https://….ngrok…/api/generate)
OLLAMA_AUTH_USER=api
OLLAMA_API_KEY=

# Gemini (required on Render — Ollama is not available in cloud)
GEMINI_API_KEY=

# CORS — add your Vercel URL after cloud deploy
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080,https://your-app.vercel.app
